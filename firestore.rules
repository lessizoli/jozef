rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function profile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function activeUser() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && profile().active == true;
    }

    function superAdmin() {
      return activeUser() && profile().role == 'superadmin';
    }

    function belongsTo(companyId) {
      return activeUser()
        && (superAdmin() || profile().companyId == companyId);
    }

    function companyAdmin(companyId) {
      return belongsTo(companyId)
        && (superAdmin() || profile().role == 'company_admin');
    }

    // A felhasználó a saját profilját olvashatja.
    match /users/{userId} {
      allow read: if activeUser()
        && (superAdmin() || request.auth.uid == userId);

      // Saját alapadatok módosíthatók, jogosultsági mezők nem.
      allow update: if activeUser()
        && request.auth.uid == userId
        && request.resource.data.companyId == resource.data.companyId
        && request.resource.data.role == resource.data.role
        && request.resource.data.active == resource.data.active;

      allow create, delete: if superAdmin();
    }

    // Cég alapadatai.
    match /companies/{companyId} {
      allow read: if belongsTo(companyId);
      allow create, update, delete: if companyAdmin(companyId);

      // A CRM működéséhez használt céges modulok.
      match /{module}/{documentId} {
        allow read, create, update, delete: if belongsTo(companyId)
          && module in [
            'projects',
            'events',
            'surveys',
            'constructions',
            'executions',
            'quotes',
            'contracts',
            'finances',
            'files'
          ];
      }

      // Jogosultsági és céges beállítások csak adminnak.
      match /{adminSection}/{documentId} {
        allow read: if belongsTo(companyId)
          && adminSection in ['members', 'settings', 'invites'];

        allow create, update, delete: if companyAdmin(companyId)
          && adminSection in ['members', 'settings', 'invites'];
      }

      // Napló csak olvasható, kliensből nem írható.
      match /activityLog/{logId} {
        allow read: if belongsTo(companyId);
        allow write: if false;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
