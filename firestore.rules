rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function userPath() {
      return /databases/$(database)/documents/users/$(uid());
    }

    function hasUserProfile() {
      return isSignedIn() && exists(userPath());
    }

    function currentUser() {
      return get(userPath()).data;
    }

    function isActiveUser() {
      return hasUserProfile() &&
        (!("active" in currentUser()) || currentUser().active == true);
    }

    function profileCompanyMatches(companyId) {
      return isActiveUser() &&
        ("companyId" in currentUser()) &&
        currentUser().companyId == companyId;
    }

    function memberPath(companyId) {
      return /databases/$(database)/documents/companies/$(companyId)/members/$(uid());
    }

    function hasMemberDocument(companyId) {
      return isSignedIn() && exists(memberPath(companyId));
    }

    function isMemberOf(companyId) {
      return isActiveUser() &&
        (hasMemberDocument(companyId) || profileCompanyMatches(companyId));
    }

    function isAdminOf(companyId) {
      return isMemberOf(companyId) && (
        (hasMemberDocument(companyId) && get(memberPath(companyId)).data.role == 'admin') ||
        (profileCompanyMatches(companyId) && currentUser().role in ['admin', 'company_admin', 'Vezető'])
      );
    }

    match /users/{userId} {
      allow read: if isSignedIn() && uid() == userId;

      allow create: if isSignedIn() && uid() == userId;

      allow update: if isSignedIn() && uid() == userId
        && request.resource.data.companyId == resource.data.companyId
        && request.resource.data.role == resource.data.role
        && request.resource.data.active == resource.data.active
        && request.resource.data.isSuperAdmin == resource.data.isSuperAdmin;

      allow delete: if false;
    }

    match /companies/{companyId} {
      allow read: if isMemberOf(companyId);
      allow create: if isSignedIn();
      allow update, delete: if isAdminOf(companyId);

      match /members/{memberId} {
        allow read: if isMemberOf(companyId);

        allow create: if isAdminOf(companyId) ||
          (isSignedIn() && uid() == memberId && profileCompanyMatches(companyId));

        allow update: if isAdminOf(companyId);
        allow delete: if isAdminOf(companyId) || uid() == memberId;
      }

      match /settings/{settingId} {
        allow read: if isMemberOf(companyId);
        allow create, update, delete: if isAdminOf(companyId);
      }

      match /invites/{inviteId} {
        allow read: if isMemberOf(companyId) ||
          (isSignedIn() && resource.data.email == request.auth.token.email);

        allow create: if isAdminOf(companyId);

        allow update: if isAdminOf(companyId) ||
          (isSignedIn() && resource.data.email == request.auth.token.email);

        allow delete: if isAdminOf(companyId);
      }

      match /projects/{projectId} {
        allow read, create, update, delete: if isMemberOf(companyId);
      }

      match /events/{eventId} {
        allow read, create, update, delete: if isMemberOf(companyId);
      }

      match /surveys/{surveyId} {
        allow read, create, update, delete: if isMemberOf(companyId);
      }

      match /constructions/{constructionId} {
        allow read, create, update, delete: if isMemberOf(companyId);
      }

      match /quotes/{quoteId} {
        allow read, create, update, delete: if isMemberOf(companyId);
      }

      match /files/{fileId} {
        allow read, create, update, delete: if isMemberOf(companyId);
      }

      match /activityLog/{logId} {
        allow read: if isMemberOf(companyId);
        allow write: if false;
      }
    }
  }
}
